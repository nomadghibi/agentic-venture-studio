{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo run build --filter=@avs/types && pnpm turbo run build --filter=@avs/web",
  "outputDirectory": "apps/web/.next",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://your-api.railway.app/api/v1/:path*"
    }
  ]
}
