NODE_ENV=development
PORT=4050

# --- Web ---
WEB_URL=http://localhost:3200
NEXT_PUBLIC_API_BASE_URL=http://localhost:4050/api/v1

# --- Database ---
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_venture_studio
#
# Supabase (use Transaction Pooler on port 6543 for serverless-safe connections):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Session ---
SESSION_COOKIE_NAME=avs_session
SESSION_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=60

# --- SMTP (optional — omit to log reset links to the API console in development) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# --- AI ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Beta access — if set, registration requires this code. Leave blank for open registration. ---
BETA_INVITE_CODE=
